{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist-types",
    "rootDir": "./src",
    "composite": true,
    "tsBuildInfoFile": "./dist-types/.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "jsx": "react-jsx",
    "allowJs": false,
    "isolatedModules": true,
    "noEmit": true,
    "moduleResolution": "Bundler"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "dist-types", "src-tauri"],
  "references": [{ "path": "../../packages/core" }, { "path": "../../packages/shared-ui" }]
}
