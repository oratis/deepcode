<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- DeepCode spawns child processes (sandboxed bash, plugin subprocesses,
       MCP stdio servers) and needs JIT for the Tao webview JS engine. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Network for DeepSeek API + future MCP -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- File access — Tauri's plugin-dialog asks the user per-folder -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <!-- Microphone — /voice records locally and transcribes with whisper.cpp -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
