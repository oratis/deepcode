{
  "name": "@deepcode/lsp",
  "version": "0.0.0",
  "private": true,
  "description": "Language-Server-Protocol bridge — exposes DeepCode actions to any LSP-capable IDE.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "deepcode-lsp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
