{
  "name": "@deepcode/shared-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TS types and constants between CLI and Mac desktop client",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -b",
    "test": "echo 'no tests in shared-ui (types only)' && exit 0",
    "lint": "echo 'lint: configured in M1' && exit 0",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
